IF TEST -z "$AGENT"
SWITCH "$ARGV0_BASENAME"
CASE "claude"
SET AGENT claude
CASE "codex"
SET AGENT codex
CASE "gemini"
SET AGENT gemini
END
END

SWITCH "$AGENT"
CASE "claude"
USE agent/claude
CASE "codex"
USE agent/codex
CASE "gemini"
USE agent/gemini
DEFAULT
IF TEST -n "$AGENT"
WARN "USE agent does not recognize agent `$AGENT`"
END
END
