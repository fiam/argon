IF TEST -n "$SHELL"
FS ALLOW READ $SHELL
EXEC ALLOW $SHELL
END
IF TEST -n "$XDG_CONFIG_HOME"
IF TEST -d "$XDG_CONFIG_HOME/fish"
FS ALLOW READ $XDG_CONFIG_HOME/fish/
END
ELSE
IF TEST -d "$HOME/.config/fish"
FS ALLOW READ $HOME/.config/fish/
END
END
IF TEST -n "$XDG_DATA_HOME"
FS ALLOW WRITE $XDG_DATA_HOME/fish/fish_history
ELSE
FS ALLOW WRITE $HOME/.local/share/fish/fish_history
END
