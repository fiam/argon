ENV ALLOW SHELL
ENV ALLOW TERM
ENV ALLOW TERM_PROGRAM
ENV ALLOW TERM_PROGRAM_VERSION
ENV ALLOW COLORTERM
ENV ALLOW SHLVL
ENV ALLOW PWD
ENV ALLOW HISTFILE
ENV ALLOW XDG_*
ENV ALLOW ZDOTDIR
ENV ALLOW BASH_ENV
ENV ALLOW ENV

SWITCH "$SHELL_NAME"
CASE "bash"
USE shell/bash
CASE "fish"
USE shell/fish
CASE "zsh"
USE shell/zsh
DEFAULT
IF TEST -n "$SHELL_NAME"
WARN "USE shell does not recognize shell `$SHELL_NAME`"
END
END
